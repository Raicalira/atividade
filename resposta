##20-Qual o intervalo médio entre ingestões por usuário?
tive que pesquisar como fazer

SELECT usuario_id, AVG(proxima_ingestao - data_hora) AS intervalo_medio
FROM (
    SELECT 
        usuario_id, data_hora,
        LEAD(data_hora) OVER (
            PARTITION BY usuario_id 
            ORDER BY data_hora
        ) AS proxima_ingestao
    FROM ingestao_agua
) AS subconsulta
WHERE proxima_ingestao IS NOT NULL
GROUP BY usuario_id
ORDER BY  intervalo_medio ASC;

